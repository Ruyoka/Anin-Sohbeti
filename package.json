    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "cypress": "^13.6.4",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.8.3",
    "start-server-and-test": "^2.1.5"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  }
}
