{
  "name": "aninsohbeti",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "npm run test:server && npm run test:e2e",
    "test:server": "node --test tests/server.test.js",
    "test:e2e": "start-server-and-test \"PORT=6100 npm run start\" http://127.0.0.1:6100/health \"cypress run\"",
