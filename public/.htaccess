# Security hardening
Options -Indexes

# Block access to sensitive files
<IfModule mod_authz_core.c>
  <FilesMatch "^(?:\.env|\.git|\.htaccess|\.htpasswd|composer\.(?:json|lock)|package(?:-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|Dockerfile|docker-compose\.ya?ml|server\.js|.*\.(?:log|sql|sqlite|bak|ini|ya?ml))$">
    Require all denied
  </FilesMatch>
</IfModule>
<IfModule !mod_authz_core.c>
  <FilesMatch "^(?:\.env|\.git|\.htaccess|\.htpasswd|composer\.(?:json|lock)|package(?:-lock)?\.json|yarn\.lock|pnpm-lock\.yaml|Dockerfile|docker-compose\.ya?ml|server\.js|.*\.(?:log|sql|sqlite|bak|ini|ya?ml))$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>

# Block hidden files/directories except .well-known
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule "(^|/)\.(?!well-known/)" - [F]
</IfModule>
